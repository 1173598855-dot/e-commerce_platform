# Copy to .env for local or server deployments. Do not commit .env.

# Required production secrets
DB_PASSWORD=change-me-to-a-strong-random-password
JWT_SECRET=change-me-to-a-random-secret-at-least-64-characters

# Required for Docker Compose Redis auth.
REDIS_PASSWORD=change-me-to-a-strong-random-redis-password

# Permission token version enforcement. Set to 1 for gray launch after permission_versions migration is applied.
PERMISSION_TOKEN_VERSION_ENFORCEMENT=0

# SMS provider settings
SMS_PROVIDER=console
SMS_CONSOLE_LOG_CODE=false
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_ENDPOINT=
SMS_APP_ID=
SMS_CODE_EXPIRE=300
SMS_COOLDOWN=60
SMS_IP_LIMIT=20
SMS_PHONE_LIMIT=10

# WeChat / mini program settings
WX_APP_ID=your_wx_app_id_here
WX_SECRET=your_wx_secret_here

# Asset/CDN settings. Leave ASSET_BASE_URL empty for local relative URLs.
ASSET_BASE_URL=
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_ACCESS_KEY_SECRET=

# Refund evidence upload settings. Keep mock for local; use oss/cos/s3 only after signing is implemented and verified.
REFUND_EVIDENCE_STORAGE_PROVIDER=mock
REFUND_EVIDENCE_STORAGE_BUCKET=
REFUND_EVIDENCE_STORAGE_REGION=
REFUND_EVIDENCE_STORAGE_ENDPOINT=
REFUND_EVIDENCE_STORAGE_ACCESS_KEY=
REFUND_EVIDENCE_STORAGE_SECRET_KEY=
REFUND_EVIDENCE_PUBLIC_BASE_URL=http://localhost:8080/uploads
REFUND_EVIDENCE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,video/mp4,application/pdf
REFUND_EVIDENCE_MAX_FILE_SIZE_BYTES=10485760
REFUND_EVIDENCE_UPLOAD_EXPIRES_SECONDS=600
REFUND_EVIDENCE_SCANNER_SECRET=change-me-to-a-strong-random-scanner-callback-secret
REFUND_EVIDENCE_SCANNER_TIMESTAMP_TOLERANCE_SECONDS=300
REFUND_EVIDENCE_RETENTION_DAYS=180
RETENTION_CLEANUP_WORKER_ENABLED=false
RETENTION_CLEANUP_DRY_RUN=true
RETENTION_CLEANUP_BATCH_SIZE=50
RETENTION_CLEANUP_WORKER_INTERVAL_MS=3600000

# Payment provider settings. Keep mock until sandbox credentials and callbacks are verified.
PAYMENT_PROVIDER=mock
PAYMENT_CALLBACK_BASE_URL=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_CERT_SERIAL_NO=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# Logistics provider settings. Keep mock locally; use kuaidi100 after credentials and callback domain are ready.
LOGISTICS_PROVIDER=mock
LOGISTICS_CALLBACK_BASE_URL=
KUAIDI100_KEY=
KUAIDI100_CUSTOMER=
KUAIDI100_SECRET=

# Order timeout worker settings.
ORDER_TIMEOUT_WORKER_ENABLED=true
ORDER_PAYMENT_TIMEOUT_MINUTES=30
ORDER_TIMEOUT_BATCH_SIZE=50
ORDER_TIMEOUT_WORKER_INTERVAL_MS=60000

# Runtime settings
NODE_ENV=production
LOG_LEVEL=info
