# 服务器配置
PORT=3000
NODE_ENV=production

# MySQL配置 - Docker 网络中使用服务名
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=ecommerce

# Redis配置 - Docker 网络中使用服务名
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=ecommerce_jwt_secret_key_2024
JWT_EXPIRES_IN=7d

# 模拟短信配置
SMS_ENABLED=true
SMS_CODE_EXPIRE=300
